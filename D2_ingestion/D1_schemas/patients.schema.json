{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Patient",
    "description": "De-identified clinical trial participant. Registered at exactly one site; enrolled in 1-3 trials (referenced, not embedded, to avoid duplication).",
    "required": [
      "patient_id", "name", "date_of_birth", "gender", "ethnicity",
      "blood_type", "bmi", "smoking_status", "diagnosis",
      "comorbidities", "site_id", "enrolled_trials", "created_at"
    ],
    "additionalProperties": true,
    "properties": {
      "patient_id": {
        "bsonType": "string",
        "pattern": "^PT-[0-9]{6}$",
        "description": "Unique. Format PT-XXXXXX."
      },
      "name": {
        "bsonType": "string",
        "description": "Synthetic full name, internal operational use only."
      },
      "date_of_birth": {
        "bsonType": "date",
        "description": "ISO 8601. 1940-01-01 to 2005-12-31."
      },
      "gender": {
        "enum": ["Male", "Female", "Non-binary", "Prefer not to say"]
      },
      "ethnicity": {
        "enum": ["Malay", "Chinese", "Indian", "Caucasian", "African", "Hispanic", "Other"]
      },
      "blood_type": {
        "enum": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"]
      },
      "bmi": {
        "bsonType": "double",
        "minimum": 15.0,
        "maximum": 45.0,
        "description": "Recorded at enrolment."
      },
      "smoking_status": {
        "enum": ["Never", "Former", "Current"]
      },
      "diagnosis": {
        "bsonType": "object",
        "description": "Embedded primary diagnosis. Always read with the patient; no independent identity.",
        "required": ["icd10_code", "description", "diagnosed_on"],
        "properties": {
          "icd10_code": { "bsonType": "string", "description": "e.g. C34.1" },
          "description": { "bsonType": "string" },
          "diagnosed_on": { "bsonType": "date" }
        }
      },
      "comorbidities": {
        "bsonType": "array",
        "minItems": 0,
        "maxItems": 5,
        "description": "0-5 pre-existing conditions (ICD-10 code + label).",
        "items": { "bsonType": "string" }
      },
      "site_id": {
        "bsonType": "string",
        "pattern": "^SITE-0[1-5]$",
        "description": "Single, permanent site assignment (SITE-01..SITE-05)."
      },
      "enrolled_trials": {
        "bsonType": "array",
        "minItems": 1,
        "maxItems": 3,
        "description": "Reference side of the many-to-many patient<->trial link. Single source of truth for enrolment.",
        "items": { "bsonType": "string", "pattern": "^NCT-[0-9]{8}$" }
      },
      "contact_info": {
        "bsonType": "object",
        "description": "Embedded synthetic contact details.",
        "properties": {
          "email": { "bsonType": "string" },
          "phone": { "bsonType": "string" },
          "emergency_contact": { "bsonType": "string" }
        }
      },
      "created_at": { "bsonType": "date" }
    }
  }
}
